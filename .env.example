ADAPTER_API_KEY=replace-with-random-secret
DAYTONA_API_KEY=replace-with-daytona-api-key
# Optional Daytona API URL (for self-hosted Daytona control plane)
DAYTONA_API_URL=
# Sandbox resources (CPU, memory, disk). Defaults to 1/1/3.
DAYTONA_SANDBOX_CPU=1
DAYTONA_SANDBOX_MEMORY=1
DAYTONA_SANDBOX_DISK=3
# Workspace root inside sandbox (set /tmp/workspace if /workspace is read-only)
WORKSPACE_ROOT=/workspace
# Optional Redis URL. If omitted, in-memory session store is used.
REDIS_URL=
# Session idle timeout (seconds)
SESSION_TTL_SECONDS=1800
# Optional upload limit in bytes (20MB default)
UPLOAD_MAX_BYTES=20971520
# Background cleanup interval in seconds
CLEANUP_INTERVAL_SECONDS=60
# Application log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
